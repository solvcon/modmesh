{
  "permissions": {
    "allow": [
      "Bash(make)",
      "Bash(make pytest:*)",
      "Bash(make gtest:*)",
      "Bash(make pilot:*)",
      "Bash(make lint:*)",
      "Bash(make cformat:*)",
      "Bash(make flake8:*)",
      "Bash(make cinclude:*)",
      "Bash(make checkascii:*)",
      "Bash(make checktws:*)",
      "Bash(make run_pilot_pytest:*)",
      "Bash(make pyprof:*)",
      "Bash(make buildext:*)",
      "Bash(make install:*)",
      "Bash(cmake:*)",
      "Bash(ctest:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(clang-format:*)",
      "Bash(clang-tidy:*)",
      "Bash(flake8:*)",
      "Bash(black:*)",
      "Bash(./build/*/gtests/run_gtest:*)",
      "Bash(ls:*)",
      "Bash(file:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git stash list:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore --staged:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-doc-images.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-source.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$CLAUDE_PROJECT_DIR/.claude/statusline.sh"
  }
}
