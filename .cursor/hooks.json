{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "command": ".cursor/hooks/check-source.sh",
        "matcher": "Write|StrReplace"
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/check-source.sh",
        "matcher": "Write|TabWrite"
      }
    ]
  }
}
